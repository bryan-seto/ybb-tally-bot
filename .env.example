# ============================================
# Production / Deployment Environment Template
# ============================================
# Copy to .env (or set these as environment variables on your host).
# For LOCAL development use .env.local.example instead.

# --- User Configuration (REQUIRED) ---
# Telegram numeric user IDs (use @userinfobot to find them).
USER_A_ID=your_user_a_id_here
USER_A_NAME=your_user_a_name_here
USER_B_ID=your_user_b_id_here
USER_B_NAME=your_user_b_name_here

# Backup messages are sent to this Telegram user ID.
BACKUP_RECIPIENT_ID=your_backup_recipient_id_here

# --- Bot Configuration (REQUIRED) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: extra authorized user IDs (comma-separated).
ALLOWED_USER_IDS=109284773,424894363

# Optional: Groq API key for additional AI models (leave blank if unused).
GROQ_API_KEY=

# --- Database Configuration (REQUIRED) ---
DATABASE_URL="postgresql://postgres:***@localhost:5432/ybb_tally_bot?schema=public"

# --- App Settings ---
PORT=10000
NODE_ENV=development # development, staging, or production

# --- Transport Settings ---
# WEBHOOK_URL is OPTIONAL. Behavior:
#   - Set to a public HTTPS URL  -> bot runs in WEBHOOK mode (needs a public endpoint + TLS).
#   - Leave BLANK/unset          -> bot runs in LONG POLLING mode (works on any VM, no public
#                                   endpoint needed). This is the recommended setup for plain
#                                   VMs such as Oracle Cloud Always Free.
WEBHOOK_URL=

# --- Observability ---
SENTRY_DSN=
